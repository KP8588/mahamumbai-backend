# =============================================
# COPY THIS FILE TO .env AND FILL IN VALUES
# cp .env.example .env
# =============================================

# Server
PORT=5000
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=any_random_long_string_here_change_this

# Database (PostgreSQL)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=digital_card_db
DB_PASS=your_postgres_password_here
DB_PORT=5432

# JWT Secret (make this long and random)
JWT_SECRET=make_this_very_long_and_random_like_64_characters

# Google OAuth (get from console.cloud.google.com)
# Leave blank if not using Google login - app still works
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Gmail for OTP emails (use App Password, not your real password)
# Leave blank if not using OTP - app still works without it
EMAIL_USER=
EMAIL_PASS=

# Razorpay (get from dashboard.razorpay.com)
# Leave blank if not using payments yet - app still works
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
